# Prisma: set PRISMA_LOG_QUERIES=1 to log every SQL query in dev (slower terminal)
# PRISMA_LOG_QUERIES=0

# Database (pick one — see docs/DATABASE-WINDOWS.md)
# Local PostgreSQL:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ugclab?schema=public"
# Neon (cloud, no Docker):
# DATABASE_URL="postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth (shared across apps)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"

# App URLs (local dev)
PLATFORM_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_URL="http://localhost:3000"
MERCHANT_ADMIN_URL="http://localhost:3001"
PLATFORM_ADMIN_URL="http://localhost:3003"
API_PORT=4000
STOREFRONT_URL="http://localhost:3002"
STOREFRONT_BASE_DOMAIN="localhost:3002"
# Subdomain stores: slug.STORE_BASE_DOMAIN (production)
STORE_BASE_DOMAIN="ugclab.store"
# Merchant Vite admin also reads STOREFRONT_* from repo root (optional alias):
# VITE_STOREFRONT_URL="http://localhost:3002"

# Payment model: mor (platform collects all, pays merchants) | connect (Stripe per merchant)
PAYMENT_MODEL=mor
# MoR payout rules (merchant requests + platform admin)
MOR_MIN_PAYOUT_CENTS=5000
MOR_PAYOUT_SCHEDULE=Weekly payouts (manual processing)
# Optional: WISE_API_KEY= for future auto-payouts via Wise

# Stripe — MoR: one platform account for all store checkouts (no Connect)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Local: stripe listen --forward-to localhost:4000/api/stripe/webhook
# Prod: Dashboard → Webhooks → POST https://your-api/api/stripe/webhook
# Events: checkout.session.completed, charge.refunded, customer.subscription.*
# Optional: Stripe Price ID for Pro plan (else price_data is used at checkout)
STRIPE_PRICE_PRO=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Shippo — auto shipping labels (merchant order detail → Shippo label)
SHIPPO_API_KEY=""

# Email notifications (merchant order alerts — Resend or SendGrid)
RESEND_API_KEY=""
# SENDGRID_API_KEY=""
EMAIL_FROM="Tescommerce <onboarding@resend.dev>"
# MoR payout request alerts to platform ops (optional)
# PLATFORM_OPS_EMAIL="ops@yourcompany.com"

# Marketing (open/click tracking, unsubscribe links)
API_PUBLIC_URL="http://localhost:4000"
MARKETING_DAILY_CAP_PER_TENANT=2000

# Defaults
DEFAULT_LOCALE="en"
APP_REGION="us"
