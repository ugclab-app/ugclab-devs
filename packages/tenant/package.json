{
  "name": "@ugclab/tenant",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./store-theme": {
      "types": "./dist/store-theme.d.ts",
      "development": "./src/store-theme.ts",
      "import": "./dist/store-theme.js",
      "default": "./dist/store-theme.js"
    },
    "./block-style": {
      "types": "./dist/block-style.d.ts",
      "development": "./src/block-style.ts",
      "import": "./dist/block-style.js",
      "default": "./dist/block-style.js"
    }
  },
  "scripts": {
    "build": "npm run build -w @ugclab/database && tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@ugclab/database": "*"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
